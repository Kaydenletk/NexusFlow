{
  "name": "nexusflow",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm dev:focus",
    "dev:focus": "concurrently -n web,extension -c green,magenta \"pnpm --filter @quantified-self/web dev\" \"pnpm --filter @quantified-self/extension build:watch\"",
    "dev:web": "pnpm --filter @quantified-self/web dev",
    "dev:extension": "pnpm --filter @quantified-self/extension dev",
    "watch:extension": "pnpm --filter @quantified-self/extension build:watch",
    "legacy:dev": "concurrently -n api,web -c blue,green \"pnpm --filter @quantified-self/api dev\" \"pnpm --filter @quantified-self/web dev\"",
    "legacy:dev:api": "pnpm --filter @quantified-self/api dev",
    "db:migrate": "pnpm legacy:db:migrate",
    "db:check": "pnpm legacy:db:check",
    "db:seed": "pnpm legacy:db:seed",
    "test": "pnpm -r test",
    "legacy:db:migrate": "pnpm --filter @quantified-self/db migrate",
    "legacy:db:check": "pnpm --filter @quantified-self/db check",
    "legacy:db:seed": "pnpm --filter @quantified-self/db seed"
  },
  "devDependencies": {
    "@types/node": "24.7.2",
    "concurrently": "9.2.1",
    "typescript": "5.9.3"
  }
}
